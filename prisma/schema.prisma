generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  Pending
  Active
  Locked
  Disabled
  Archived
}

enum AuthProvider {
  Discord
}

enum RoleScopeType {
  Global
  Unit
  StaffSection
}

enum RecoveryStatus {
  Open
  Approved
  Denied
  Completed
  Cancelled
}

enum BootstrapStatus {
  Open
  Completed
  Expired
  Revoked
}

enum SessionRevocationScope {
  Account
  Global
}

enum CatalogStatus {
  Draft
  Active
  Inactive
  Archived
}

enum RecruitingSource {
  Reddit
  Steam
  Discord
}

enum MilitaryBranch {
  Army
  Navy
  AirForce
  Marines
  CoastGuard
}

enum PersonnelStatus {
  Applicant
  Recruit
  Probationary
  Active
  Reserve
  LeaveOfAbsence
  ExtendedLeaveOfAbsence
  Inactive
  AWOL
  Separated
  Discharged
  DoNotRehire
  HonorableDischarge
  OtherThanHonorableDischarge
  DishonorableDischarge
}

enum ApplicationStatus {
  Draft
  Submitted
  MoreInfoRequested
  RecruiterScreening
  RecruiterRecommended
  TargetUnitReview
  Accepted
  Denied
  Withdrawn
  Closed
  Converted
}

enum ApplicationReviewStage {
  RecruiterScreening
  TargetUnitReview
  FinalDecision
}

enum AssignmentType {
  Primary
  Secondary
  Temporary
  Staff
}

enum EventStatus {
  Draft
  Scheduled
  RosterFinalized
  Completed
  Cancelled
  Archived
}

enum EventRosterSource {
  Template
  UnitRoster
  ManualAdjustment
}

enum AttendanceStatus {
  Expected
  Present
  Partial
  Late
  Excused
  Absent
  NoShow
  LeaveOfAbsence
  NotRequired
  PendingReview
}

enum LoaStatus {
  Submitted
  UnderReview
  Approved
  Denied
  Cancelled
  Withdrawn
  Active
  Completed
  Returned
}

enum LoaApprovalLevel {
  UnitStaff
  Escalated
}

enum QualificationStatus {
  Recommended
  Pending
  Active
  Expired
  Suspended
  Revoked
  Waived
}

enum RequestStatus {
  Draft
  Submitted
  UnderReview
  Approved
  Denied
  Cancelled
  Completed
  Voided
}

enum TrainingOutcome {
  Pass
  Fail
}

enum VisibilityLevel {
  Applicant
  Member
  Staff
  Command
  System
  Restricted
}

enum SupportTicketStatus {
  Open
  PendingStaff
  PendingMember
  Resolved
  Closed
  Voided
}

enum NotificationStatus {
  Unread
  Read
  Archived
}

enum NotificationDeliveryChannel {
  InApp
}

enum AuditSeverity {
  Info
  Notice
  Warning
  Critical
}

enum IntegrationLogStatus {
  Pending
  Success
  Failure
  Voided
}

model Account {
  id                         String                   @id @default(cuid())
  displayName                String?
  email                      String?
  timezone                   String?
  status                     AccountStatus            @default(Pending)
  statusReason               String?                  @db.Text
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  activatedAt                DateTime?
  claimedAt                  DateTime?
  lockedAt                   DateTime?
  disabledAt                 DateTime?
  archivedAt                 DateTime?
  lastLoginAt                DateTime?
  authIdentities             AuthIdentity[]
  sessions                   Session[]
  revokedSessions            Session[]                @relation("SessionRevokedBy")
  issuedSessionRevocations   SessionRevocation[]      @relation("SessionRevocationIssuedBy")
  targetedSessionRevocations SessionRevocation[]      @relation("SessionRevocationTargetAccount")
  roleAssignments            RoleAssignment[]         @relation("RoleAssignmentAccount")
  grantedRoleAssignments     RoleAssignment[]         @relation("RoleAssignmentGrantedBy")
  recoverySubjects           AccountRecoveryRequest[] @relation("RecoverySubject")
  recoveryRequests           AccountRecoveryRequest[] @relation("RecoveryRequester")
  recoveryReviews            AccountRecoveryRequest[] @relation("RecoveryReviewer")
  recoveryCompletions        AccountRecoveryRequest[] @relation("RecoveryCompleter")
  verifiedBootstraps         AccessBootstrap[]        @relation("BootstrapVerifiedAccount")
  completedBootstraps        AccessBootstrap[]        @relation("BootstrapCompletedBy")
  personnelProfile           PersonnelProfile?
  createdProfiles            PersonnelProfile[]       @relation("ProfileCreatedBy")
  applications               Application[]
  claimedApplications        Application[]            @relation("ApplicationClaimedBy")
  supportTicketsCreated      SupportTicket[]          @relation("SupportTicketCreatedBy")
  supportTicketsAssigned     SupportTicket[]          @relation("SupportTicketAssignedTo")
  supportComments            SupportTicketComment[]
  notifications              Notification[]
  auditEvents                AuditLog[]               @relation("AuditActor")
  targetedAuditEvents        AuditLog[]               @relation("AuditTargetAccount")
  integrationLogs            IntegrationLog[]

  @@index([status])
  @@index([email])
}

model AuthIdentity {
  id                      String       @id @default(cuid())
  accountId               String
  account                 Account      @relation(fields: [accountId], references: [id])
  provider                AuthProvider
  providerAccountId       String
  username                String?
  displayName             String?
  lastGuildVerifiedAt     DateTime?
  guildMembershipRequired Boolean      @default(true)
  linkedAt                DateTime     @default(now())
  unlinkedAt              DateTime?
  isPrimary               Boolean      @default(true)
  metadata                Json?

  @@unique([provider, providerAccountId])
  @@index([accountId])
}

model Session {
  id                  String    @id @db.VarChar(191)
  accountId           String
  account             Account   @relation(fields: [accountId], references: [id])
  data                Json
  expiresAt           DateTime
  lastAuthenticatedAt DateTime?
  recentAuthExpiresAt DateTime?
  revokedAt           DateTime?
  revokedByAccountId  String?
  revokedByAccount    Account?  @relation("SessionRevokedBy", fields: [revokedByAccountId], references: [id])
  revocationReason    String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([accountId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model SessionRevocation {
  id                String                 @id @default(cuid())
  scope             SessionRevocationScope
  targetAccountId   String?
  targetAccount     Account?               @relation("SessionRevocationTargetAccount", fields: [targetAccountId], references: [id])
  issuedByAccountId String?
  issuedByAccount   Account?               @relation("SessionRevocationIssuedBy", fields: [issuedByAccountId], references: [id])
  reason            String                 @db.Text
  createdAt         DateTime               @default(now())

  @@index([scope])
  @@index([targetAccountId])
  @@index([createdAt])
}

model Role {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String?
  precedence  Int               @default(0)
  status      CatalogStatus     @default(Draft)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  permissions PermissionGrant[]
  assignments RoleAssignment[]
}

model Permission {
  id                 String            @id @default(cuid())
  key                String            @unique
  module             String
  action             String
  name               String
  description        String?
  sensitiveCategory  String?
  requiresRecentAuth Boolean           @default(false)
  status             CatalogStatus     @default(Draft)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  roles              PermissionGrant[]
}

model PermissionGrant {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model RoleAssignment {
  id                       String        @id @default(cuid())
  accountId                String
  account                  Account       @relation("RoleAssignmentAccount", fields: [accountId], references: [id])
  roleId                   String
  role                     Role          @relation(fields: [roleId], references: [id])
  scopeType                RoleScopeType @default(Global)
  scopeIncludesDescendants Boolean       @default(true)
  unitId                   String?
  unit                     Unit?         @relation(fields: [unitId], references: [id])
  staffSectionId           String?
  staffSection             StaffSection? @relation(fields: [staffSectionId], references: [id])
  grantedByAccountId       String?
  grantedByAccount         Account?      @relation("RoleAssignmentGrantedBy", fields: [grantedByAccountId], references: [id])
  startsAt                 DateTime      @default(now())
  endsAt                   DateTime?
  reason                   String?       @db.Text
  createdAt                DateTime      @default(now())

  @@index([accountId])
  @@index([roleId])
  @@index([unitId])
  @@index([staffSectionId])
}

model AccountRecoveryRequest {
  id                String         @id @default(cuid())
  subjectAccountId  String?
  subjectAccount    Account?       @relation("RecoverySubject", fields: [subjectAccountId], references: [id])
  requestedById     String?
  requestedBy       Account?       @relation("RecoveryRequester", fields: [requestedById], references: [id])
  reviewedById      String?
  reviewedBy        Account?       @relation("RecoveryReviewer", fields: [reviewedById], references: [id])
  completedById     String?
  completedBy       Account?       @relation("RecoveryCompleter", fields: [completedById], references: [id])
  status            RecoveryStatus @default(Open)
  requestType       String
  requestedIdentity Json?
  reason            String         @db.Text
  decisionNote      String?        @db.Text
  createdAt         DateTime       @default(now())
  reviewedAt        DateTime?
  completedAt       DateTime?

  @@index([subjectAccountId])
  @@index([status])
}

model AccessBootstrap {
  id                      String          @id @default(cuid())
  status                  BootstrapStatus @default(Open)
  configuredDiscordIdHash String?
  verifiedAccountId       String?
  verifiedAccount         Account?        @relation("BootstrapVerifiedAccount", fields: [verifiedAccountId], references: [id])
  completedByAccountId    String?
  completedByAccount      Account?        @relation("BootstrapCompletedBy", fields: [completedByAccountId], references: [id])
  setupScope              String          @default("catalog-access")
  reason                  String?         @db.Text
  createdAt               DateTime        @default(now())
  verifiedAt              DateTime?
  completedAt             DateTime?
  expiresAt               DateTime?

  @@index([status])
  @@index([verifiedAccountId])
}

model Unit {
  id                   String                    @id @default(cuid())
  parentId             String?
  parent               Unit?                     @relation("UnitTree", fields: [parentId], references: [id])
  children             Unit[]                    @relation("UnitTree")
  key                  String                    @unique
  name                 String
  type                 String
  status               CatalogStatus             @default(Draft)
  hierarchyBase        Int                       @default(0)
  recruitingOpen       Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  roleAssignments      RoleAssignment[]
  personnel            PersonnelProfile[]
  unitAssignments      PersonnelUnitAssignment[]
  billets              Billet[]
  mos                  MOS[]
  targetedApplications Application[]             @relation("ApplicationTargetUnit")
  applicationInterests ApplicationInterestUnit[]

  @@index([parentId])
  @@index([status])
  @@index([recruitingOpen])
}

model Rank {
  id                String                 @id @default(cuid())
  key               String                 @unique
  name              String
  abbreviation      String?
  grade             String?
  precedence        Int                    @default(0)
  status            CatalogStatus          @default(Draft)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  personnel         PersonnelProfile[]
  history           PersonnelRankHistory[]
  minimumForBillets Billet[]               @relation("BilletMinimumRank")
  promotionRequests PromotionRequest[]
  promotionRecords  PromotionRecord[]
}

model Billet {
  id                String                      @id @default(cuid())
  unitId            String?
  unit              Unit?                       @relation(fields: [unitId], references: [id])
  key               String                      @unique
  name              String
  category          String?
  minimumRankId     String?
  minimumRank       Rank?                       @relation("BilletMinimumRank", fields: [minimumRankId], references: [id])
  commandPrecedence Int                         @default(0)
  status            CatalogStatus               @default(Draft)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  personnel         PersonnelProfile[]
  history           PersonnelBilletAssignment[]

  @@index([unitId])
  @@index([minimumRankId])
  @@index([status])
}

model StaffSection {
  id              String            @id @default(cuid())
  key             String            @unique
  identifier      String?
  name            String
  function        String?           @db.Text
  status          CatalogStatus     @default(Draft)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  roleAssignments RoleAssignment[]
  assignments     StaffAssignment[]
}

model MOS {
  id                           String                  @id @default(cuid())
  key                          String                  @unique
  identifier                   String
  name                         String
  unitId                       String?
  unit                         Unit?                   @relation(fields: [unitId], references: [id])
  status                       CatalogStatus           @default(Draft)
  recruitingOpen               Boolean                 @default(false)
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  primaryPersonnel             PersonnelProfile[]      @relation("PrimaryPersonnelMOS")
  secondaryPersonnel           PersonnelProfile[]      @relation("SecondaryPersonnelMOS")
  history                      PersonnelMOSHistory[]
  applicationDesiredSelections ApplicationDesiredMOS[]

  @@index([unitId])
  @@index([status])
  @@index([recruitingOpen])
}

model PersonnelProfile {
  id                    String                      @id @default(cuid())
  accountId             String                      @unique
  account               Account                     @relation(fields: [accountId], references: [id])
  name                  String
  status                PersonnelStatus             @default(Recruit)
  currentRankId         String?
  currentRank           Rank?                       @relation(fields: [currentRankId], references: [id])
  currentUnitId         String?
  currentUnit           Unit?                       @relation(fields: [currentUnitId], references: [id])
  currentBilletId       String?
  currentBillet         Billet?                     @relation(fields: [currentBilletId], references: [id])
  currentMOSId          String?
  currentMOS            MOS?                        @relation("PrimaryPersonnelMOS", fields: [currentMOSId], references: [id])
  currentSecondaryMOSId String?
  currentSecondaryMOS   MOS?                        @relation("SecondaryPersonnelMOS", fields: [currentSecondaryMOSId], references: [id])
  goodStanding          Boolean                     @default(true)
  militaryService       Boolean                     @default(false)
  source                RecruitingSource?
  joinedAt              DateTime?
  acceptedAt            DateTime?
  claimedAt             DateTime?
  separatedAt           DateTime?
  createdByAccountId    String?
  createdByAccount      Account?                    @relation("ProfileCreatedBy", fields: [createdByAccountId], references: [id])
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  statusHistory         PersonnelStatusHistory[]
  rankHistory           PersonnelRankHistory[]
  unitAssignments       PersonnelUnitAssignment[]
  billetAssignments     PersonnelBilletAssignment[]
  mosHistory            PersonnelMOSHistory[]
  staffAssignments      StaffAssignment[]
  standingHistory       PersonnelStandingHistory[]
  convertedApplications Application[]               @relation("ApplicationConvertedProfile")
  loaRequests           LoaRequest[]
  eventAttendance       EventAttendance[]
  trainingRecords       TrainingRecord[]
  qualifications        PersonnelQualification[]
  promotionRequests     PromotionRequest[]
  promotionRecords      PromotionRecord[]
  awardRequests         AwardRequest[]
  awardRecords          AwardRecord[]
  disciplinaryRecords   DisciplinaryRecord[]
  administrativeNotes   AdministrativeNote[]
  supportTickets        SupportTicket[]
  auditTargets          AuditLog[]                  @relation("AuditTargetPersonnel")

  @@index([status])
  @@index([currentUnitId])
  @@index([name])
}

model PersonnelStatusHistory {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  oldStatus          PersonnelStatus?
  newStatus          PersonnelStatus
  effectiveAt        DateTime         @default(now())
  changedByAccountId String?
  reason             String           @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([newStatus])
}

model PersonnelRankHistory {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  rankId             String
  rank               Rank             @relation(fields: [rankId], references: [id])
  effectiveAt        DateTime         @default(now())
  endedAt            DateTime?
  changedByAccountId String?
  reason             String?          @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([rankId])
}

model PersonnelUnitAssignment {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  unitId             String
  unit               Unit             @relation(fields: [unitId], references: [id])
  assignmentType     AssignmentType   @default(Primary)
  effectiveAt        DateTime         @default(now())
  endedAt            DateTime?
  changedByAccountId String?
  reason             String?          @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([unitId])
}

model PersonnelBilletAssignment {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  billetId           String
  billet             Billet           @relation(fields: [billetId], references: [id])
  assignmentType     AssignmentType   @default(Primary)
  effectiveAt        DateTime         @default(now())
  endedAt            DateTime?
  changedByAccountId String?
  reason             String?          @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([billetId])
}

model PersonnelMOSHistory {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  mosId              String
  mos                MOS              @relation(fields: [mosId], references: [id])
  assignmentType     AssignmentType   @default(Primary)
  effectiveAt        DateTime         @default(now())
  endedAt            DateTime?
  changedByAccountId String?
  reason             String?          @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([mosId])
  @@index([assignmentType])
}

model StaffAssignment {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  staffSectionId     String
  staffSection       StaffSection     @relation(fields: [staffSectionId], references: [id])
  assignmentType     AssignmentType   @default(Staff)
  effectiveAt        DateTime         @default(now())
  endedAt            DateTime?
  changedByAccountId String?
  reason             String?          @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([staffSectionId])
}

model PersonnelStandingHistory {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  oldGoodStanding    Boolean?
  newGoodStanding    Boolean
  effectiveAt        DateTime         @default(now())
  changedByAccountId String?
  reason             String           @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
}

model Application {
  id                              String                     @id @default(cuid())
  accountId                       String
  account                         Account                    @relation(fields: [accountId], references: [id])
  targetUnitId                    String?
  targetUnit                      Unit?                      @relation("ApplicationTargetUnit", fields: [targetUnitId], references: [id])
  status                          ApplicationStatus          @default(Draft)
  formVersion                     String
  firstName                       String?
  lastName                        String?
  age                             Int?
  timeZone                        String?
  reasonForJoining                String?                    @db.Text
  source                          RecruitingSource?
  priorService                    Boolean                    @default(false)
  priorArma                       Boolean                    @default(false)
  leadership                      Boolean                    @default(false)
  leadershipDetails               String?                    @db.Text
  submittedAt                     DateTime?
  claimedByAccountId              String?
  claimedByAccount                Account?                   @relation("ApplicationClaimedBy", fields: [claimedByAccountId], references: [id])
  claimedAt                       DateTime?
  recruiterRecommendedByAccountId String?
  recruiterRecommendedAt          DateTime?
  unitDecisionByAccountId         String?
  unitDecisionAt                  DateTime?
  decidedAt                       DateTime?
  closedAt                        DateTime?
  convertedProfileId              String?
  convertedProfile                PersonnelProfile?          @relation("ApplicationConvertedProfile", fields: [convertedProfileId], references: [id])
  createdAt                       DateTime                   @default(now())
  updatedAt                       DateTime                   @updatedAt
  answers                         ApplicationAnswer[]
  servicePeriods                  ApplicationServicePeriod[]
  armaUnits                       ApplicationArmaUnit[]
  interestedUnits                 ApplicationInterestUnit[]
  desiredMOS                      ApplicationDesiredMOS[]
  statusHistory                   ApplicationStatusHistory[]
  notes                           ApplicationReviewNote[]

  @@index([accountId])
  @@index([claimedByAccountId])
  @@index([targetUnitId])
  @@index([status])
  @@index([convertedProfileId])
}

model ApplicationServicePeriod {
  id            String         @id @default(cuid())
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id])
  branch        MilitaryBranch
  mos           String
  years         Int
  sortOrder     Int            @default(0)

  @@index([applicationId])
}

model ApplicationArmaUnit {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  unitName      String
  joinedAt      DateTime?
  leftAt        DateTime?
  stillMember   Boolean     @default(false)
  reasonLeft    String?     @db.Text
  sortOrder     Int         @default(0)

  @@index([applicationId])
}

model ApplicationInterestUnit {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  unitId        String
  unit          Unit        @relation(fields: [unitId], references: [id])
  sortOrder     Int         @default(0)

  @@unique([applicationId, unitId])
  @@index([unitId])
}

model ApplicationDesiredMOS {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  mosId         String
  mos           MOS         @relation(fields: [mosId], references: [id])
  sortOrder     Int         @default(0)

  @@unique([applicationId, mosId])
  @@index([mosId])
}

model ApplicationAnswer {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  section       String?
  questionKey   String
  questionText  String      @db.Text
  answer        String      @db.Text
  sortOrder     Int         @default(0)

  @@index([applicationId])
}

model ApplicationStatusHistory {
  id                 String                  @id @default(cuid())
  applicationId      String
  application        Application             @relation(fields: [applicationId], references: [id])
  oldStatus          ApplicationStatus?
  newStatus          ApplicationStatus
  stage              ApplicationReviewStage?
  changedByAccountId String?
  reason             String                  @db.Text
  permissionContext  Json?
  createdAt          DateTime                @default(now())
  auditLogId         String?

  @@index([applicationId])
  @@index([newStatus])
}

model ApplicationReviewNote {
  id              String                  @id @default(cuid())
  applicationId   String
  application     Application             @relation(fields: [applicationId], references: [id])
  authorAccountId String?
  stage           ApplicationReviewStage?
  body            String                  @db.Text
  visibility      VisibilityLevel         @default(Staff)
  createdAt       DateTime                @default(now())

  @@index([applicationId])
}

model EventTemplate {
  id             String        @id @default(cuid())
  name           String
  eventType      String
  recurrenceRule String?
  status         CatalogStatus @default(Draft)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  events         Event[]
}

model Event {
  id                             String            @id @default(cuid())
  templateId                     String?
  template                       EventTemplate?    @relation(fields: [templateId], references: [id])
  title                          String
  eventType                      String
  status                         EventStatus       @default(Scheduled)
  rosterSource                   EventRosterSource @default(Template)
  sourceUnitId                   String?
  startsAt                       DateTime
  endsAt                         DateTime?
  location                       String?
  details                        String?           @db.Text
  ownerAccountId                 String?
  createdByAccountId             String?
  rosterFinalizedAt              DateTime?
  rosterFinalizedByAccountId     String?
  attendanceFinalizedAt          DateTime?
  attendanceFinalizedByAccountId String?
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt
  attendance                     EventAttendance[]

  @@index([templateId])
  @@index([sourceUnitId])
  @@index([startsAt])
  @@index([status])
}

model EventAttendance {
  id                   String             @id @default(cuid())
  eventId              String
  event                Event              @relation(fields: [eventId], references: [id])
  personnelProfileId   String
  personnelProfile     PersonnelProfile   @relation(fields: [personnelProfileId], references: [id])
  status               AttendanceStatus   @default(Expected)
  expectedSource       EventRosterSource?
  reviewerAccountId    String?
  reviewedAt           DateTime?
  correctedByAccountId String?
  correctedAt          DateTime?
  correctionReason     String?            @db.Text
  notes                String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  auditLogId           String?

  @@unique([eventId, personnelProfileId])
  @@index([personnelProfileId])
  @@index([status])
}

model LoaRequest {
  id                   String           @id @default(cuid())
  personnelProfileId   String
  personnelProfile     PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  status               LoaStatus        @default(Submitted)
  approvalLevel        LoaApprovalLevel @default(UnitStaff)
  submittedByAccountId String?
  startsAt             DateTime
  endsAt               DateTime
  reasonCategory       String
  details              String?          @db.Text
  escalatedAt          DateTime?
  escalationReason     String?          @db.Text
  reviewedByAccountId  String?
  decidedAt            DateTime?
  cancelledAt          DateTime?
  withdrawnAt          DateTime?
  earlyReturnAt        DateTime?
  returnConfirmedAt    DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  auditLogId           String?

  @@index([personnelProfileId])
  @@index([status])
  @@index([startsAt, endsAt])
}

model TrainingCourse {
  id             String                @id @default(cuid())
  key            String?               @unique
  name           String
  category       String?
  description    String?               @db.Text
  status         CatalogStatus         @default(Draft)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  qualifications CourseQualification[]
  sessions       TrainingSession[]
  records        TrainingRecord[]
}

model Qualification {
  id               String                   @id @default(cuid())
  key              String                   @unique
  name             String
  category         String?
  expiresAfterDays Int?
  status           CatalogStatus            @default(Draft)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  courses          CourseQualification[]
  personnel        PersonnelQualification[]
}

model CourseQualification {
  courseId        String
  qualificationId String
  course          TrainingCourse @relation(fields: [courseId], references: [id])
  qualification   Qualification  @relation(fields: [qualificationId], references: [id])

  @@id([courseId, qualificationId])
}

model TrainingSession {
  id                  String           @id @default(cuid())
  courseId            String
  course              TrainingCourse   @relation(fields: [courseId], references: [id])
  completedAt         DateTime
  recordedByAccountId String?
  instructorAccountId String?
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  records             TrainingRecord[]

  @@index([courseId])
  @@index([completedAt])
  @@index([recordedByAccountId])
}

model TrainingRecord {
  id                    String                   @id @default(cuid())
  sessionId             String?
  session               TrainingSession?         @relation(fields: [sessionId], references: [id])
  personnelProfileId    String
  personnelProfile      PersonnelProfile         @relation(fields: [personnelProfileId], references: [id])
  courseId              String
  course                TrainingCourse           @relation(fields: [courseId], references: [id])
  status                RequestStatus            @default(Completed)
  outcome               TrainingOutcome          @default(Pass)
  recordedByAccountId   String?
  completedAt           DateTime?
  instructorAccountId   String?
  notes                 String?                  @db.Text
  auditLogId            String?
  grantedQualifications PersonnelQualification[] @relation("TrainingRecordQualificationGrants")

  @@index([sessionId])
  @@index([personnelProfileId])
  @@index([courseId])
  @@index([status])
  @@index([outcome])
}

model PersonnelQualification {
  id                 String              @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile    @relation(fields: [personnelProfileId], references: [id])
  qualificationId    String
  qualification      Qualification       @relation(fields: [qualificationId], references: [id])
  trainingRecordId   String?
  trainingRecord     TrainingRecord?     @relation("TrainingRecordQualificationGrants", fields: [trainingRecordId], references: [id])
  status             QualificationStatus @default(Pending)
  grantedAt          DateTime?
  expiresAt          DateTime?
  grantedByAccountId String?
  changedByAccountId String?
  evidence           String?             @db.Text
  notes              String?             @db.Text
  auditLogId         String?

  @@unique([personnelProfileId, qualificationId])
  @@index([status])
  @@index([trainingRecordId])
}

model PromotionRequest {
  id                   String           @id @default(cuid())
  personnelProfileId   String
  personnelProfile     PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  requestedRankId      String
  requestedRank        Rank             @relation(fields: [requestedRankId], references: [id])
  status               RequestStatus    @default(Submitted)
  requestedByAccountId String?
  approvedByAccountId  String?
  reason               String?          @db.Text
  decidedAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  auditLogId           String?

  @@index([personnelProfileId])
  @@index([status])
}

model PromotionRecord {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  rankId             String
  rank               Rank             @relation(fields: [rankId], references: [id])
  sourceRequestId    String?
  effectiveAt        DateTime
  reason             String?          @db.Text
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([rankId])
}

model Award {
  id           String         @id @default(cuid())
  key          String?        @unique
  abbreviation String?
  name         String
  type         String?
  category     String?
  status       CatalogStatus  @default(Draft)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  requests     AwardRequest[]
  records      AwardRecord[]
}

model AwardRequest {
  id                   String           @id @default(cuid())
  personnelProfileId   String
  personnelProfile     PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  awardId              String
  award                Award            @relation(fields: [awardId], references: [id])
  status               RequestStatus    @default(Submitted)
  requestedByAccountId String?
  approvedByAccountId  String?
  citation             String?          @db.Text
  decidedAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  auditLogId           String?

  @@index([personnelProfileId])
  @@index([status])
}

model AwardRecord {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  awardId            String
  award              Award            @relation(fields: [awardId], references: [id])
  sourceRequestId    String?
  awardedAt          DateTime
  citation           String?          @db.Text
  visibility         VisibilityLevel  @default(Staff)
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([awardId])
}

model DisciplinaryRecord {
  id                  String           @id @default(cuid())
  personnelProfileId  String
  personnelProfile    PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  actionType          String
  summary             String
  details             String?          @db.Text
  status              RequestStatus    @default(Completed)
  visibility          VisibilityLevel  @default(Restricted)
  createdByAccountId  String?
  approvedByAccountId String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  auditLogId          String?

  @@index([personnelProfileId])
  @@index([visibility])
}

model AdministrativeNote {
  id                 String           @id @default(cuid())
  personnelProfileId String
  personnelProfile   PersonnelProfile @relation(fields: [personnelProfileId], references: [id])
  noteType           String
  body               String           @db.Text
  visibility         VisibilityLevel  @default(Staff)
  authorAccountId    String?
  createdAt          DateTime         @default(now())
  auditLogId         String?

  @@index([personnelProfileId])
  @@index([visibility])
}

model SupportTicket {
  id                  String                 @id @default(cuid())
  createdByAccountId  String
  createdByAccount    Account                @relation("SupportTicketCreatedBy", fields: [createdByAccountId], references: [id])
  assignedToAccountId String?
  assignedToAccount   Account?               @relation("SupportTicketAssignedTo", fields: [assignedToAccountId], references: [id])
  personnelProfileId  String?
  personnelProfile    PersonnelProfile?      @relation(fields: [personnelProfileId], references: [id])
  category            String
  queueKey            String
  intakeOnly          Boolean                @default(false)
  title               String
  description         String                 @db.Text
  status              SupportTicketStatus    @default(Open)
  severity            AuditSeverity          @default(Info)
  resolvedAt          DateTime?
  closedAt            DateTime?
  voidedAt            DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  comments            SupportTicketComment[]
  auditLogId          String?

  @@index([createdByAccountId])
  @@index([assignedToAccountId])
  @@index([queueKey])
  @@index([status])
}

model SupportTicketComment {
  id              String          @id @default(cuid())
  ticketId        String
  ticket          SupportTicket   @relation(fields: [ticketId], references: [id])
  authorAccountId String
  authorAccount   Account         @relation(fields: [authorAccountId], references: [id])
  body            String          @db.Text
  visibility      VisibilityLevel @default(Staff)
  createdAt       DateTime        @default(now())

  @@index([ticketId])
  @@index([authorAccountId])
}

model Notification {
  id                String                      @id @default(cuid())
  accountId         String
  account           Account                     @relation(fields: [accountId], references: [id])
  category          String
  deliveryChannel   NotificationDeliveryChannel @default(InApp)
  workflowEvent     String?
  title             String
  body              String?                     @db.Text
  status            NotificationStatus          @default(Unread)
  relatedRecordType String?
  relatedRecordId   String?
  createdAt         DateTime                    @default(now())
  readAt            DateTime?

  @@index([accountId])
  @@index([status])
}

model AuditLog {
  id                       String            @id @default(cuid())
  actorAccountId           String?
  actorAccount             Account?          @relation("AuditActor", fields: [actorAccountId], references: [id])
  targetAccountId          String?
  targetAccount            Account?          @relation("AuditTargetAccount", fields: [targetAccountId], references: [id])
  targetPersonnelProfileId String?
  targetPersonnelProfile   PersonnelProfile? @relation("AuditTargetPersonnel", fields: [targetPersonnelProfileId], references: [id])
  module                   String
  action                   String
  recordType               String?
  recordId                 String?
  oldValue                 Json?
  newValue                 Json?
  reason                   String?           @db.Text
  severity                 AuditSeverity     @default(Info)
  protectedWrite           Boolean           @default(true)
  ipSessionMetadata        Json?
  createdAt                DateTime          @default(now())

  @@index([actorAccountId])
  @@index([targetAccountId])
  @@index([targetPersonnelProfileId])
  @@index([recordType, recordId])
  @@index([createdAt])
}

model IntegrationLog {
  id                String               @id @default(cuid())
  provider          String
  action            String
  status            IntegrationLogStatus @default(Pending)
  accountId         String?
  account           Account?             @relation(fields: [accountId], references: [id])
  relatedRecordType String?
  relatedRecordId   String?
  requestPayload    Json?
  responsePayload   Json?
  error             String?              @db.Text
  createdAt         DateTime             @default(now())

  @@index([provider])
  @@index([status])
  @@index([accountId])
  @@index([relatedRecordType, relatedRecordId])
}

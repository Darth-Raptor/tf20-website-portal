NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret

# Required for database-backed portal features.
# mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=mysql://tf20_user:replace-password@localhost:3306/tf20

# Required for Discord login in the private portal.
DISCORD_CLIENT_ID=replace-with-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Optional for pulling Steam display names, profile links, and avatars after
# Steam OpenID verifies the user's Steam64 ID.
STEAM_WEB_API_KEY=replace-with-steam-web-api-key

# Production notes:
# - Keep the live .env only on the VPS in /opt/tf20/app/.env
# - Run npm run prisma:generate, npm run prisma:migrate, and npm run db:seed
#   before first launch in a new environment.
